{
  "name": "md-kanban",
  "displayName": "MD Kanban",
  "description": "Markdownファイルとして保存されるカンバンボードでプロジェクトのタスクやTODOを管理します",
  "version": "0.4.0",
  "publisher": "jeddak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jebakumarj/md-kanban"
  },
  "bugs": {
    "url": "https://github.com/jebakumarj/md-kanban/issues"
  },
  "homepage": "https://github.com/jebakumarj/md-kanban#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "kanban",
    "markdown",
    "tasks",
    "todo",
    "project management",
    "board"
  ],
  "activationEvents": [
    "onView:md-kanban.boards",
    "onView:md-kanban.codeTodos",
    "onView:md-kanban.overdueTasks",
    "onView:md-kanban.calendar",
    "onCommand:md-kanban.openBoard",
    "onCommand:md-kanban.createBoard",
    "onCommand:md-kanban.openBoardFile",
    "onCommand:md-kanban.refreshBoards",
    "onCommand:md-kanban.refreshCodeTodos",
    "onCommand:md-kanban.refreshOverdueTasks",
    "onCommand:md-kanban.showOverdueTasks",
    "onCommand:md-kanban.refreshTimeline",
    "onCommand:md-kanban.showTimeline",
    "onCommand:md-kanban.refreshCalendar",
    "onCommand:md-kanban.showCalendar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-kanban.openBoard",
        "title": "カンバンボードを開く",
        "category": "カンバン"
      },
      {
        "command": "md-kanban.createBoard",
        "title": "新しいカンバンボードを作成",
        "category": "カンバン",
        "icon": "$(add)"
      },
      {
        "command": "md-kanban.openBoardFile",
        "title": "カンバンボードを開く",
        "category": "カンバン"
      },
      {
        "command": "md-kanban.addTodoToBoard",
        "title": "TODOをボードに追加",
        "category": "カンバン",
        "icon": "$(add)"
      },
      {
        "command": "md-kanban.refreshBoards",
        "title": "カンバンボードを更新",
        "category": "カンバン",
        "icon": "$(refresh)"
      },
      {
        "command": "md-kanban.refreshCodeTodos",
        "title": "TODOを更新",
        "category": "カンバン",
        "icon": "$(refresh)"
      },
      {
        "command": "md-kanban.refreshOverdueTasks",
        "title": "期限超過タスクを更新",
        "category": "カンバン",
        "icon": "$(refresh)"
      },
      {
        "command": "md-kanban.showOverdueTasks",
        "title": "期限超過タスクを表示",
        "category": "カンバン",
        "icon": "$(warning)"
      },
      {
        "command": "md-kanban.refreshTimeline",
        "title": "タイムラインを更新",
        "category": "カンバン",
        "icon": "$(refresh)"
      },
      {
        "command": "md-kanban.showTimeline",
        "title": "タイムラインを表示",
        "category": "カンバン",
        "icon": "$(list-tree)"
      },
      {
        "command": "md-kanban.refreshCalendar",
        "title": "カレンダーを更新",
        "category": "カンバン",
        "icon": "$(refresh)"
      },
      {
        "command": "md-kanban.showCalendar",
        "title": "カレンダーを表示",
        "category": "カンバン",
        "icon": "$(calendar)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-kanban",
          "title": "MD Kanban",
          "icon": "src/image/kanban-activity.svg"
        }
      ]
    },
    "views": {
      "md-kanban": [
        {
          "id": "md-kanban.boards",
          "name": "カンバンボード"
        },
        {
          "id": "md-kanban.codeTodos",
          "name": "TODO"
        },
        {
          "id": "md-kanban.overdueTasks",
          "name": "期限超過タスク"
        },
        {
          "id": "md-kanban.calendar",
          "name": "カレンダー",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "md-kanban.boards",
        "contents": "カンバンボードが見つかりません。\n[カンバンボードを作成](command:md-kanban.createBoard)"
      },
      {
        "view": "md-kanban.codeTodos",
        "contents": "このワークスペースには設定済みのTODOコメントが見つかりません。"
      },
      {
        "view": "md-kanban.overdueTasks",
        "contents": "期限超過のカンバンタスクは見つかりません。"
      },
      {
        "view": "md-kanban.calendar",
        "contents": "期限日が設定されたカンバンタスクは見つかりません。"
      }
    ],
    "configuration": {
      "title": "MD Kanban",
      "properties": {
        "mdKanban.todoInclude": {
          "type": "array",
          "default": [
            "**/*"
          ],
          "items": {
            "type": "string"
          },
          "description": "MD KanbanのTODOサイドパネルでスキャンするファイルのグロブパターン。"
        },
        "mdKanban.todoExclude": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/out/**",
            "**/dist/**",
            "**/build/**",
            "**/coverage/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "MD KanbanのTODOサイドパネルのスキャンから除外するグロブパターン。ボードファイルと.gitは常に除外されます。"
        },
        "mdKanban.todoKeywords": {
          "type": "array",
          "default": [
            "TODO",
            "FIXME",
            "BUG",
            "HACK",
            "NOTE"
          ],
          "items": {
            "type": "string"
          },
          "description": "MD KanbanのTODOサイドパネルに表示するコメントキーワード。"
        },
        "mdKanban.completedColumnGlobs": {
          "type": "array",
          "default": [
            "完了",
            "クローズ",
            "リリース済み",
            "アーカイブ済み",
            "Done",
            "Closed",
            "Shipped",
            "Archived"
          ],
          "items": {
            "type": "string"
          },
          "description": "期限超過のカンバンタスクをスキャンする際に、完了済みとみなす列名のグロブパターン。"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "md-kanban.createBoard",
          "when": "view == md-kanban.boards",
          "group": "navigation"
        },
        {
          "command": "md-kanban.refreshBoards",
          "when": "view == md-kanban.boards",
          "group": "navigation"
        },
        {
          "command": "md-kanban.refreshCodeTodos",
          "when": "view == md-kanban.codeTodos",
          "group": "navigation"
        },
        {
          "command": "md-kanban.refreshOverdueTasks",
          "when": "view == md-kanban.overdueTasks",
          "group": "navigation"
        },
        {
          "command": "md-kanban.refreshCalendar",
          "when": "view == md-kanban.calendar",
          "group": "navigation"
        },
        {
          "command": "md-kanban.showTimeline",
          "when": "view == md-kanban.calendar && mdKanban.calendarModeCalendar",
          "group": "navigation"
        },
        {
          "command": "md-kanban.showCalendar",
          "when": "view == md-kanban.calendar && mdKanban.calendarModeTimeline",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "md-kanban.openBoardFile",
          "when": "view == md-kanban.boards && viewItem == kanbanBoard",
          "group": "inline"
        },
        {
          "command": "md-kanban.addTodoToBoard",
          "when": "view == md-kanban.codeTodos && viewItem == codeTodo",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "md-kanban.addTodoToBoard",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "md-kanban.openBoardFile",
          "when": "resourceFilename =~ /(^kanban\\.md$|^\\.kanban\\.md$|\\.kanban\\.md$)/",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "md-kanban.openBoardFile",
          "when": "resourceFilename =~ /(^kanban\\.md$|^\\.kanban\\.md$|\\.kanban\\.md$)/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.9.3"
  }
}
